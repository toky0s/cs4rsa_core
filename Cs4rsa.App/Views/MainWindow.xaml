<views:MainWindowBase
    x:Class="Cs4rsa.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:info="clr-namespace:Cs4rsa.Module.Shared;assembly=Cs4rsa.Module.Shared"
    xmlns:local="clr-namespace:Cs4rsa.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:views="clr-namespace:Cs4rsa.App.Views"
    Title="Xếp lịch"
    Width="1200"
    Height="741.641"
    prism:ViewModelLocator.AutoWireViewModel="True"
    TextElement.FontSize="13"
    TextElement.FontWeight="Regular"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="Auto"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <DockPanel>
        <!--  Toolbar đặt ở trên cùng  -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="Xếp lịch" />
                <Button Content="Open" />
                <Button Content="Save" />
                <Separator />
                <Button Content="Cut" />
                <Button Content="Copy" />
                <Button Content="Paste" />
            </ToolBar>
        </ToolBarTray>

        <Grid DockPanel.Dock="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <!--  Nội dung chính  -->
            <Border Grid.Column="0">
                <ContentControl prism:RegionManager.RegionName="{x:Static info:RegionInfo.Manual}" />
            </Border>
            <GridSplitter
                Grid.Column="1"
                Width="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch" />
            <Border Grid.Column="2">
                <TabControl>
                    <TabItem Header="Notifications" />
                </TabControl>
            </Border>
        </Grid>
    </DockPanel>
</views:MainWindowBase>