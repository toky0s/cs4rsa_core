<UserControl
    x:Class="Cs4rsa.Views.UserControls.NotificationItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:notiService="clr-namespace:Cs4rsa.Service.Notification.Models;assembly=Cs4rsa.Service.Notification"
    xmlns:prism="http://prismlibrary.com/"
    d:DataContext="{d:DesignInstance Type=notiService:Notification,
                                     IsDesignTimeCreatable=True}"
    mc:Ignorable="d">
    <Grid
        HorizontalAlignment="Stretch"
        d:Height="120"
        d:Width="300"
        Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,4"
            d:Text="Notification"
            FontWeight="Bold"
            Text="{Binding Title}" />
        <TextBlock
            Grid.Row="1"
            Margin="0,0,0,4"
            d:Text="You just delete a subject"
            FontFamily="13"
            Text="{Binding Content}"
            TextWrapping="Wrap" />
        <TextBlock
            Grid.Row="2"
            d:Text="10:00 2024-06-12"
            FontSize="9"
            FontStyle="Italic"
            Text="{Binding CreatedOn}" />
    </Grid>
</UserControl>
