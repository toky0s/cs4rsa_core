<UserControl
    x:Class="Cs4rsa.Module.ManuallySchedule.Views.MainScheduling"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:btnstyle="clr-namespace:Cs4rsa.UI.Helper;assembly=Cs4rsa.UI.Helper"
    xmlns:cvt="clr-namespace:Cs4rsa.WPF.Converter;assembly=Cs4rsa.WPF.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:info="clr-namespace:Cs4rsa.Module.ManuallySchedule"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:schedule="clr-namespace:Cs4rsa.UI.ScheduleTable.CustomControls;assembly=Cs4rsa.UI.ScheduleTable"
    xmlns:shared="clr-namespace:Cs4rsa.Module.Shared;assembly=Cs4rsa.Module.Shared"
    xmlns:uihelper="clr-namespace:Cs4rsa.UI.Helper;assembly=Cs4rsa.UI.Helper"
    xmlns:views="clr-namespace:Cs4rsa.Module.ManuallySchedule.Views"
    xmlns:vm="clr-namespace:Cs4rsa.Module.ManuallySchedule.ViewModels"
    Name="root"
    d:DataContext="{d:DesignInstance Type=vm:MainSchedulingViewModel,
                                     IsDesignTimeCreatable=True}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <UserControl.Resources>

        <ResourceDictionary>
            <shared:BindingProxy x:Key="Proxy" Data="{Binding}" />
            <cvt:GreaterThanZeroConverter x:Key="GreaterZero"></cvt:GreaterThanZeroConverter>
            <cvt:BooleanToVisibilityConverter x:Key="BoolToVis" />
            <cvt:StringListJoinConverter x:Key="JoinString" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Cs4rsa.UI.Helper;component/ButtonStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="100*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TabControl Grid.Row="0" SelectedIndex="{Binding SearchBoxSelectedIndex}">
                <TabItem Header="Search">
                    <Border>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox
                                        Grid.Column="0"
                                        ItemsSource="{Binding Disciplines}"
                                        SelectedItem="{Binding SelectedDiscipline}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border>
                                                    <TextBlock Text="{Binding Name}" />
                                                </Border>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <GridSplitter
                                        Grid.Column="1"
                                        Width="4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch" />
                                    <ComboBox
                                        Grid.Column="2"
                                        ItemsSource="{Binding DisciplineKeywordModels}"
                                        SelectedItem="{Binding SelectedKeyword}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border>
                                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                        <Border Margin="0,0,10,0" VerticalAlignment="Center">
                                                            <Ellipse
                                                                Width="12"
                                                                Height="12"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Fill="{Binding Color}" />
                                                        </Border>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Keyword1}" />
                                                        <TextBlock VerticalAlignment="Center" Text=" - " />
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding SubjectName}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Border Grid.Column="3" Margin="4,0,0,0">
                                        <Button
                                            Width="30"
                                            Command="{Binding AddCommand}"
                                            Content="+" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Grid.Row="1">
                                <Grid>
                                    <TextBox Height="20" uihelper:TextBoxHelper.Placeholder="Search your subjects..." />
                                </Grid>
                            </Border>
                            <Border Grid.Row="2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <ListBox
                                        Grid.Row="0"
                                        HorizontalContentAlignment="Stretch"
                                        ItemsSource="{Binding SubjectModels}"
                                        SelectedItem="{Binding SelectedSubjectModel}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                        <Setter Property="Cursor" Value="Wait" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                                <Setter Property="ContextMenu">
                                                    <Setter.Value>
                                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                            <ContextMenu.Style>
                                                                <Style TargetType="ContextMenu">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding IsDownloading}" Value="False" />
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </MultiDataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContextMenu.Style>
                                                            <MenuItem
                                                                Command="{Binding Data.GotoCourseCommand, Source={StaticResource Proxy}}"
                                                                CommandParameter="{Binding}"
                                                                Header="Open link" />
                                                            <MenuItem Command="{Binding Data.CopyErrorCommand, Source={StaticResource Proxy}}" Header="Copy error" />
                                                            <MenuItem
                                                                Command="{Binding Data.DeleteCommand, Source={StaticResource Proxy}}"
                                                                CommandParameter="{Binding}"
                                                                Header="Delete" />
                                                            <MenuItem
                                                                Command="{Binding Data.DetailCommand, Source={StaticResource Proxy}}"
                                                                CommandParameter="{Binding}"
                                                                Header="Details" />
                                                        </ContextMenu>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition />
                                                                <RowDefinition />
                                                            </Grid.RowDefinitions>
                                                            <Border Grid.Row="0">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse
                                                                        Width="8"
                                                                        Height="8"
                                                                        Margin="0,0,4,0"
                                                                        Fill="{Binding Color}" />
                                                                    <TextBlock FontSize="10" Text="{Binding SubjectCode}" />
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Grid.Row="1">
                                                                <Grid>
                                                                    <TextBlock Text="{Binding SubjectName}" />
                                                                </Grid>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                    <Button
                                                        Grid.Column="1"
                                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        ToolTip="Delete"
                                                        Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}, ConverterParameter=True}">
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontFamily="Segoe MDL2 Assets"
                                                            FontSize="16"
                                                            Text="" />
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel Grid.Row="1" HorizontalAlignment="Right">
                                        <Button Command="{Binding DeleteAllCommand}" Content="Delete All" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </TabItem>
                <TabItem Header="Store">
                    <ListBox ItemsSource="{Binding UserSchedules}" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition></RowDefinition>
                                        <RowDefinition></RowDefinition>
                                        <RowDefinition></RowDefinition>
                                    </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{Binding Name}" FontSize="13" FontWeight="DemiBold"></TextBlock>
                                    <TextBlock Grid.Row="1" Text="{Binding SaveDate, StringFormat={}{0:ddd dd/MM/yyyy HH:mm}}" FontSize="10"></TextBlock>
                                    <StackPanel HorizontalAlignment="Right" Grid.Row="2" Orientation="Horizontal">
                                        <Button Command="{Binding Data.DeleteUserScheduleCommand, Source={StaticResource Proxy}}" CommandParameter="{Binding}"
                                                Content="Delete" Margin="0 0 4 0"></Button>
                                        <Button Command="{Binding Data.LoadUserScheduleCommand, Source={StaticResource Proxy}}" CommandParameter="{Binding}" Content="Load..."></Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
                <TabItem Header="Details" />
            </TabControl>
            <GridSplitter
                Grid.Row="1"
                Height="5"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Background="White" />
            <TabControl Grid.Row="2">
                <TabItem>
                    <TabItem.Style>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSubjectModel}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TabItem.Style>
                    <TabItem.Header>
                        <Border>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedSubjectModel.SubjectCode}" />
                                <Button Style="{StaticResource IconButtonStyle}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="10"
                                        Text="&#xE16E;" />
                                </Button>
                            </StackPanel>
                        </Border>
                    </TabItem.Header>
                    <Border>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ListBox
                                Grid.Row="0"
                                ItemsSource="{Binding ClassGroupModels}"
                                SelectedItem="{Binding SelectedClassGroup}"
                                SelectionMode="Single">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border>
                                            <Grid>
                                                <TextBlock Text="{Binding Name}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Row="1" HorizontalAlignment="Right">
                                <!--<Button Command="{Binding DeleteAllChooseCommand}" Content="Delete All" />-->
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>
                <TabItem Header="Security" />
                <TabItem Header="Details" />
            </TabControl>
        </Grid>
        <GridSplitter
            Grid.Column="1"
            Width="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Stretch"
            Background="White" />
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="7*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0">
                <TabControl>
                    <TabItem Header="Calendar">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Expander
                                    Grid.Row="0"
                                    Header="Học kỳ 1"
                                    IsExpanded="True">
                                    <schedule:ScheduleView Week="{Binding Week1}" />
                                </Expander>
                                <Expander
                                    Grid.Row="1"
                                    Header="Học kỳ 2"
                                    IsExpanded="True">
                                    <schedule:ScheduleView Week="{Binding Week2}" />
                                </Expander>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
            <GridSplitter
                Grid.Row="1"
                Height="4"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center" />
            <Border Grid.Row="2">
                <TabControl>
                    <TabItem Header="Selected classes">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DataGrid
                                Grid.Row="0"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                ItemsSource="{Binding SelectedClassGroupModels}">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn />
                                    <DataGridTemplateColumn>
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="Color" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Rectangle Fill="{Binding Color}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Binding="{Binding Name}" Header="Subject code" />
                                    <DataGridTextColumn Binding="{Binding ClassGroup.SubjectName}" Header="Subject name" />
                                    <DataGridTextColumn
                                        Binding="{Binding ClassGroup.RegisterCodes, Converter={StaticResource JoinString}, ConverterParameter=',', FallbackValue='-', TargetNullValue='-'}"
                                        Header="Register codes"
                                        IsReadOnly="True" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border Grid.Row="1">
                                <StackPanel
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Button Command="{Binding DeleteAllChooseCommand}" Content="Unselect All" />
                                    <Button Content="Save" Command="{Binding SaveCommand}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Warning" />
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>
