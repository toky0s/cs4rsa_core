<UserControl
    x:Class="Cs4rsa.Module.ManuallySchedule.Views.MainScheduling"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:btnstyle="clr-namespace:Cs4rsa.UI.Helper;assembly=Cs4rsa.UI.Helper"
    xmlns:cvt="clr-namespace:Cs4rsa.WPF.Converter;assembly=Cs4rsa.WPF.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:info="clr-namespace:Cs4rsa.Module.ManuallySchedule"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:schedule="clr-namespace:Cs4rsa.UI.ScheduleTable.CustomControls;assembly=Cs4rsa.UI.ScheduleTable"
    xmlns:shared="clr-namespace:Cs4rsa.Module.Shared;assembly=Cs4rsa.Module.Shared"
    xmlns:uihelper="clr-namespace:Cs4rsa.UI.Helper;assembly=Cs4rsa.UI.Helper"
    xmlns:views="clr-namespace:Cs4rsa.Module.ManuallySchedule.Views"
    xmlns:vm="clr-namespace:Cs4rsa.Module.ManuallySchedule.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:MainSchedulingViewModel,
                                     IsDesignTimeCreatable=True}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <cvt:BooleanToVisibilityConverter x:Key="BoolToVis" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Cs4rsa.UI.Helper;component/ButtonStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="100*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TabControl Grid.Row="0">
                <TabItem Header="Tìm kiếm">
                    <Border>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox
                                        Grid.Column="0"
                                        ItemsSource="{Binding Disciplines}"
                                        SelectedItem="{Binding SelectedDiscipline}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border>
                                                    <TextBlock Text="{Binding Name}" />
                                                </Border>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <GridSplitter
                                        Grid.Column="1"
                                        Width="4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch" />
                                    <ComboBox
                                        Grid.Column="2"
                                        ItemsSource="{Binding DisciplineKeywordModels}"
                                        SelectedItem="{Binding SelectedKeyword}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border>
                                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                        <Border Margin="0,0,10,0" VerticalAlignment="Center">
                                                            <Ellipse
                                                                Width="12"
                                                                Height="12"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Fill="{Binding Color}" />
                                                        </Border>
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Keyword1}" />
                                                        <TextBlock VerticalAlignment="Center" Text=" - " />
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding SubjectName}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Border Grid.Column="3" Margin="4,0,0,0">
                                        <Button
                                            Width="30"
                                            Command="{Binding AddCommand}"
                                            Content="+" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Grid.Row="1">
                                <Grid>
                                    <TextBox Height="20" uihelper:TextBoxHelper.Placeholder="Tìm kiếm môn học của bạn..." />
                                </Grid>
                            </Border>
                            <Border Grid.Row="2">
                                <ListBox ItemsSource="{Binding SubjectModels}" SelectedItem="{Binding SelectedSubjectModel}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition />
                                                        <RowDefinition />
                                                    </Grid.RowDefinitions>
                                                    <Border Grid.Row="0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Ellipse
                                                                Width="8"
                                                                Height="8"
                                                                Margin="0,0,4,0"
                                                                Fill="{Binding Color}" />
                                                            <TextBlock FontSize="10" Text="{Binding SubjectCode}" />
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Grid.Row="1">
                                                        <Grid>
                                                            <TextBlock Text="{Binding SubjectName}" />
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Grid>
                    </Border>
                </TabItem>
                <TabItem Header="Security" />
                <TabItem Header="Details" />
            </TabControl>
            <GridSplitter
                Grid.Row="1"
                Height="5"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Background="White" />
            <TabControl Grid.Row="2">
                <TabItem Visibility="{Binding SelectedSubjectModel, Converter={StaticResource BoolToVis}}">
                    <TabItem.Header>
                        <Border>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedSubjectModel.SubjectCode}" />
                                <Button Style="{StaticResource IconButtonStyle}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="10"
                                        Text="&#xE16E;" />
                                </Button>
                            </StackPanel>
                        </Border>
                    </TabItem.Header>
                    <Border>
                        <Grid>
                            <ListBox ItemsSource="{Binding ClassGroupModels}" SelectedItem="{Binding SelectedClassGroup}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border>
                                            <Grid>
                                                <TextBlock Text="{Binding Name}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </TabItem>
                <TabItem Header="Security" />
                <TabItem Header="Details" />
            </TabControl>
        </Grid>
        <GridSplitter
            Grid.Column="1"
            Width="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Stretch"
            Background="White" />
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="7*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0">
                <TabControl>
                    <TabItem Header="Lịch">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Expander Grid.Row="0" Header="Học kỳ 1">
                                    <schedule:ScheduleView />
                                </Expander>
                                <Expander Grid.Row="1" Header="Học kỳ 2">
                                    <schedule:ScheduleView />
                                </Expander>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
            <GridSplitter
                Grid.Row="1"
                Height="4"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center" />
            <Border Grid.Row="2">
                <TabControl>
                    <TabItem Header="Selected classes">
                        <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding SelectedClassGroupModels}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding SubjectCode}" Header="Subject code" />
                                <DataGridTextColumn Binding="{Binding ClassGroup.SubjectName}" Header="Subject name" />
                                <DataGridTextColumn Binding="{Binding ClassGroup.}" Header="Descriptioin" />
                                <DataGridCheckBoxColumn
                                    Binding="{Binding IsSpecialClassGroup}"
                                    Header="Has multiple register code"
                                    IsReadOnly="True" />
                                <!--<DataGridCheckBoxColumn Binding="{Binding IsActive}" Header="Active" />-->
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Warning" />
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>
