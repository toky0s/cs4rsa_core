<UserControl x:Class="Cs4rsa.Module.ManuallySchedule.Dialogs.Views.ScheduleDetailUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cs4rsa.Module.ManuallySchedule.Dialogs.Views"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:Cs4rsa.Module.ManuallySchedule.Dialogs.ViewModels"
             d:DesignHeight="450" d:DesignWidth="800"
             xmlns:cvt="clr-namespace:Cs4rsa.WPF.Converter;assembly=Cs4rsa.WPF.Converter"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DataContext="{d:DesignInstance Type=vm:ScheduleDetailUCViewModel}">
    <UserControl.Resources>
        <cvt:BooleanToVisibilityConverter x:Key="BoolToVis"></cvt:BooleanToVisibilityConverter>
    </UserControl.Resources>
    <Border Padding="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0 0 0 4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
            <TextBlock HorizontalAlignment="Left" Grid.Column="0">
                <Run>Name: </Run>
                <Run Text="{Binding UserSchedule.Name}" FontWeight="DemiBold"></Run>
            </TextBlock>
                <TextBlock 
                    Visibility="{Binding IsAvailable, Converter={StaticResource BoolToVis}}" 
                    Foreground="#27ae60" 
                    Text="✅ Available" 
                    Grid.Column="1" 
                    HorizontalAlignment="Right" 
                    ToolTip="This schedule is available for this semester"
                    ></TextBlock>
            </Grid>
            <TextBlock Grid.Row="1" Margin="0 0 0 4">
                <Run>Created On: </Run>
                <Run Text="{Binding UserSchedule.SaveDate, StringFormat={}{0:ddd dd/MM/yyyy HH:mm}}" ></Run>
            </TextBlock>
            <DataGrid 
                Grid.Row="2"
                ItemsSource="{Binding UserSubjects}" 
                AutoGenerateColumns="False" 
                CanUserAddRows="False" 
                CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Subject Code" Binding="{Binding SubjectCode}" />
                    <DataGridTextColumn Header="Subject Name" Binding="{Binding SubjectName}" />
                    <DataGridTextColumn Header="Class Group" Binding="{Binding ClassGroup}" />
                    <DataGridTextColumn Header="Register Code" Binding="{Binding RegisterCode}" />
                    <DataGridTextColumn Header="Selected Class" Binding="{Binding SchoolClass}" />
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="3">
                <Button Content="Load" Command="{Binding LoadCommand}"></Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
