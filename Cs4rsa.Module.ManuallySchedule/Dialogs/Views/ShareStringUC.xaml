<UserControl
    x:Class="Cs4rsa.Module.ManuallySchedule.Dialogs.Views.ShareStringUC"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:vm="clr-namespace:Cs4rsa.Module.ManuallySchedule.Dialogs.ViewModels"
    d:DesignHeight="200"
    d:DesignWidth="400"
    d:DataContext="{d:DesignInstance Type=vm:ShareStringUCViewModel}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="Width" Value="360"></Setter>
            <Setter Property="Height" Value="240"></Setter>
            <Setter Property="prism:Dialog.WindowStartupLocation" Value="CenterScreen" />
            <Setter Property="ResizeMode" Value="CanResizeWithGrip"/>
            <Setter Property="ShowInTaskbar" Value="False"/>
        </Style>
    </prism:Dialog.WindowStyle>
    <Border Padding="4">
        <Grid  HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <TextBox
                Margin="0 0 0 4"
                VerticalScrollBarVisibility="Auto"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                Grid.Row="0"
                Background="#f5f5f5"
                IsReadOnly="True"
                Text="{Binding ShareString}" />
            <Button
                Grid.Row="1"
                FontFamily="Segoe UI Emoji"
                Command="{Binding CopyCommand}"
                Content="📋" />
        </Grid>
    </Border>
</UserControl>
